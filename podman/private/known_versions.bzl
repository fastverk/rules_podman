# Asset URL: github.com/<repo>/releases/download/v<version>/<asset>.
GITHUB_DOWNLOAD = "https://github.com/{repo}/releases/download/v{version}/{asset}"

# Per host platform. `{version}` interpolates the release version where
# the archive nests under a versioned dir.
#
# Fields:
#   repo        : GitHub repo the asset is published from.
#   asset       : release asset filename to download.
#   engine      : True  -> daemonless local engine bundle (Linux). The
#                          repository rule generates a launcher that
#                          points podman at the bundled runtimes,
#                          helpers, and configs.
#                 False -> single client binary (macOS/Windows); needs a
#                          reachable Podman service / `podman machine`.
#   bundle_top  : (engine) top-level dir the tarball extracts into; the
#                 binary is <bundle_top>/usr/local/bin/podman.
#   binary      : (client) path to the podman binary inside the archive.
PLATFORMS = {
